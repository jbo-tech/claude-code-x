# Template for a provider env file.
#
# 1. Copy to ~/.config/claude-code-x/<provider>.env  (e.g. glm.env)
# 2. Fill in ANTHROPIC_AUTH_TOKEN (see two patterns below)
# 3. chmod 600 the file
#
# NEVER commit a real .env — only this .example is versioned (see .gitignore).
# ccx refuses to load any .env that is not chmod 600/400.

# ─── Pattern A: source the central key store (recommended) ────────────────────
# Avoids duplicating keys — one place to rotate them.
#
# # shellcheck source=/dev/null
# . "$HOME/.config/llm-provider-keys/providers.env"
# ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
# ANTHROPIC_AUTH_TOKEN=$ZAI_API_KEY
# ANTHROPIC_MODEL="glm-5.1"

# ─── Pattern B: standalone (key in this file) ─────────────────────────────────
#
# ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
# ANTHROPIC_AUTH_TOKEN="REPLACE_ME"
# ANTHROPIC_MODEL="glm-5.1"

# ─── Model overrides (optional, both patterns) ───────────────────────────────
# ANTHROPIC_DEFAULT_OPUS_MODEL="glm-5.1"
# ANTHROPIC_DEFAULT_SONNET_MODEL="glm-4.7"
# ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
# CLAUDE_CODE_SUBAGENT_MODEL="glm-5.1"
# CLAUDE_CODE_EFFORT_LEVEL="max"

# ─── Known base URLs ─────────────────────────────────────────────────────────
# GLM / z.ai   : https://api.z.ai/api/anthropic
# Kimi/Moonshot : https://api.moonshot.ai/anthropic
# DeepSeek      : https://api.deepseek.com/anthropic
# OpenRouter    : https://openrouter.ai/api/v1/chat/completions
