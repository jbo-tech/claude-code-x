#!/bin/sh
# ccx — launch Claude Code routed to an alternative provider.
#
# Usage:
#   ccx <provider> [claude args...]   launch Claude Code on that provider
#   ccx add [name]                    add a new provider (interactive)
#   ccx                               show help + provider list
#
# Reads provider environment (base URL, auth token, model names) from
#   ~/.config/claude-code-x/<provider>.env
# then replaces this process with `claude`. The token lives only in this
# short-lived process's environment — never in settings.json, never in your
# interactive shell, and (with `exec`) no parent process holds it.
#
# POSIX sh on purpose: maximally durable, no shell-specific behaviour.

set -u

CONFIG_DIR="${CLAUDE_CODE_X_DIR:-$HOME/.config/claude-code-x}"
CENTRAL_STORE="${LLM_PROVIDER_KEYS:-$HOME/.config/llm-provider-keys/providers.env}"

# --- presentation (colour only when stderr is a terminal) -------------------
if [ -t 2 ]; then
	B=$(printf '\033[1m')  # bold
	D=$(printf '\033[2m')  # dim
	C=$(printf '\033[36m') # cyan
	R=$(printf '\033[0m')  # reset
else
	B='' D='' C='' R=''
fi

# host part of a provider's base URL, for the listing (token never read out)
provider_host() {
	grep -m1 '^ANTHROPIC_BASE_URL=' "$1" 2>/dev/null |
		sed -e 's/^[^=]*=//' -e "s/^[\"']//" -e "s/[\"'].*\$//" \
			-e 's#^https\{0,1\}://##' -e 's#/.*$##'
}

show_help() {
	{
		printf '\n  %s✦ ccx%s — Claude Code provider switcher\n\n' "$B$C" "$R"
		printf '  %sUsage%s\n' "$B" "$R"
		printf '    %sccx <provider>%s   launch Claude Code on <provider>\n' "$C" "$R"
		printf '    %sccx add [name]%s   add a new provider (interactive)\n' "$C" "$R"
		printf '    %sccx%s              show this help\n\n' "$C" "$R"

		printf '  %sProviders%s\n' "$B" "$R"
		found=0
		if [ -d "$CONFIG_DIR" ]; then
			for f in "$CONFIG_DIR"/*.env; do
				[ -e "$f" ] || continue
				found=1
				name=$(basename "$f" .env)
				host=$(provider_host "$f")
				printf '    %s%-12s%s %s→ %s%s\n' "$C" "$name" "$R" "$D" "${host:-?}" "$R"
			done
		fi
		[ "$found" = 0 ] &&
			printf '    %s(none yet — add one with: ccx add)%s\n' "$D" "$R"
		printf '\n  %sclaude%s (without ccx) stays on official Anthropic.\n\n' "$D" "$R"
	} >&2
}

# --- ccx add ----------------------------------------------------------------
# Single-quote a value for safe sourcing (neutralises $, `, etc.).
shell_quote() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

add_provider() {
	name="${1:-}"
	if [ -z "$name" ]; then
		printf '%sProvider name%s (e.g. glm): ' "$B" "$R" >&2
		read -r name
	fi
	case "$name" in
		'' | */* | *' '* | *.env)
			echo "ccx: invalid provider name '$name'" >&2
			return 1
			;;
	esac

	mkdir -p "$CONFIG_DIR"
	chmod 700 "$CONFIG_DIR"
	env_file="$CONFIG_DIR/$name.env"
	if [ -e "$env_file" ]; then
		printf '%s already exists — overwrite? [y/N] ' "$env_file" >&2
		read -r ans
		case "$ans" in y | Y | yes) : ;; *)
			echo "aborted." >&2
			return 1
			;;
		esac
	fi

	printf 'Base URL (Anthropic-compatible endpoint): ' >&2
	read -r base
	printf 'Default model name: ' >&2
	read -r model

	use_store=n
	if [ -r "$CENTRAL_STORE" ]; then
		printf 'Use central key store (%s)? [Y/n] ' "$CENTRAL_STORE" >&2
		read -r ans
		case "$ans" in n | N | no) use_store=n ;; *) use_store=y ;; esac
	fi

	if [ "$use_store" = y ]; then
		printf 'Variable name in store (e.g. DEEPSEEK_API_KEY): ' >&2
		read -r key_var
		if [ -z "$key_var" ]; then
			echo "ccx: variable name is required." >&2
			return 1
		fi
		if ! grep -q "^${key_var}=" "$CENTRAL_STORE" 2>/dev/null; then
			printf '%s⚠%s  %s not found in %s — add it there first.\n' \
				"$C" "$R" "$key_var" "$CENTRAL_STORE" >&2
			return 1
		fi
		token_line="ANTHROPIC_AUTH_TOKEN=\$$key_var"
	else
		# token: read with echo off so it never shows on screen or in scrollback
		printf 'Auth token (hidden): ' >&2
		saved=$(stty -g 2>/dev/null) && stty -echo 2>/dev/null
		read -r token
		[ -n "$saved" ] && stty "$saved" 2>/dev/null
		printf '\n' >&2
		if [ -z "$token" ]; then
			echo "ccx: auth token is required." >&2
			return 1
		fi
		token_line="ANTHROPIC_AUTH_TOKEN=$(shell_quote "$token")"
	fi

	if [ -z "$base" ]; then
		echo "ccx: base URL is required." >&2
		return 1
	fi

	umask 077
	{
		printf '# %s — added via `ccx add`\n' "$name"
		[ "$use_store" = y ] && printf '# shellcheck source=/dev/null\n. "$HOME/.config/llm-provider-keys/providers.env"\n'
		printf 'ANTHROPIC_BASE_URL=%s\n' "$(shell_quote "$base")"
		printf '%s\n' "$token_line"
		[ -n "$model" ] && printf 'ANTHROPIC_MODEL=%s\n' "$(shell_quote "$model")"
	} >"$env_file"
	chmod 600 "$env_file"

	printf '%s✓%s wrote %s (600).  Launch with: %sccx %s%s\n' \
		"$C" "$R" "$env_file" "$C" "$name" "$R" >&2
	printf '  Add model overrides (sonnet/haiku/…) by editing that file.\n' >&2
}

# --- dispatch ---------------------------------------------------------------
cmd="${1:-}"
case "$cmd" in
	'' | -h | --help | help)
		show_help
		exit 0
		;;
	add)
		shift
		add_provider "$@"
		exit $?
		;;
esac

# --- launch a provider ------------------------------------------------------
provider="$cmd"
shift

env_file="$CONFIG_DIR/$provider.env"
if [ ! -r "$env_file" ]; then
	echo "ccx: unknown provider '$provider' (no readable $env_file)" >&2
	show_help
	exit 1
fi

# Refuse a secret file readable by group/other — fail loud rather than leak.
perms=$(stat -c '%a' "$env_file" 2>/dev/null || stat -f '%Lp' "$env_file" 2>/dev/null || echo '???')
case "$perms" in
	600 | 400) : ;;
	*)
		echo "ccx: refusing $env_file: perms $perms (want 600)" >&2
		echo "     fix with: chmod 600 $env_file" >&2
		exit 1
		;;
esac

# Load provider env (set -a => every assignment is exported), harden, then exec.
set -a
# shellcheck disable=SC1090
. "$env_file"
set +a
ulimit -c 0 2>/dev/null || true # no core dump can capture the token

exec claude "$@"
